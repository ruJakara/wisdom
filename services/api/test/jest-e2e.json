{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "moduleNameMapper": {
    "^src/(.*)$": "<rootDir>/../src/$1",
    "^@shared/(.*)$": "<rootDir>/../../../packages/shared/$1"
  },
  "coverageDirectory": "../coverage-e2e",
  "testTimeout": 30000
}
