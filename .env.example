# Stage 0 baseline: bot-only + stable WebApp stub

# Required for bot start
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Optional bot settings
TELEGRAM_BOT_USERNAME=your_bot_username
TELEGRAM_WEBAPP_URL=https://your-webapp-url.com/
WEB_APP_URL=https://your-webapp-url.com/

# Common app settings
NODE_ENV=development
PORT=3000
RENDER_URL=http://localhost:3000
WEBAPP_BASE_URL=https://your-webapp-url.com/
THROTTLE_TTL=60000
THROTTLE_LIMIT=100

# Frontend settings
VITE_API_URL=http://localhost:3000/api
VITE_API_TIMEOUT_MS=10000
VITE_WEBAPP_URL=https://your-webapp-url.com/
# Global fallback flag for all frontend API modules
VITE_USE_MOCK_API=false
# Stage 3 split mode:
# - core (auth/user/game) works with live backend MVP
# - Stage 4 live: core also includes upgrade/inventory/shop/leaderboard/referral
# - extended flag is optional for future non-core modules
VITE_USE_MOCK_CORE_API=false
VITE_USE_MOCK_EXTENDED_API=true

# Backend settings (not required for bot-only mode)
DATABASE_URL=postgresql://postgres:password@localhost:5432/night_hunger?schema=public
REDIS_URL=redis://localhost:6379
JWT_SECRET=replace_with_strong_secret
JWT_EXPIRES_IN=7d

# Optional integrations
PAYMENT_PROVIDER_TOKEN=your_payment_token
S3_BUCKET=your_bucket_name
S3_REGION=us-east-1
S3_ACCESS_KEY=your_access_key
S3_SECRET_KEY=your_secret_key
